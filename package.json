{
  "name": "life-dashboard",
  "version": "0.1.79",
  "private": true,
  "description": "Obsidian Life Dashboard plugin development helpers",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "deploy": "node scripts/sync-plugin.mjs --bump",
    "dev": "node scripts/sync-plugin.mjs --watch",
    "build:plugin": "node esbuild.config.mjs production",
    "build:watch": "node esbuild.config.mjs watch",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.4",
    "typescript": "^5.7.3"
  }
}
